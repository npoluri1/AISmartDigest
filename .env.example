# ─── App ─────────────────────────────────────────────────────────────
APP_NAME=AISmartDigest
APP_VERSION=0.1.0
DEBUG=true

# ─── LLM (for summarization) ──────────────────────────────────────────
# Options: ollama, openai
LLM_PROVIDER=ollama
LLM_MODEL=llama3
LLM_API_KEY=
LLM_API_BASE=http://localhost:11434
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120

# ─── Browser ──────────────────────────────────────────────────────────
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=500
BROWSER_COOKIE_DIR=./cookies

# ─── Storage ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/smart_digest.db
OUTPUT_DIR=./data/output

# ─── Processing ───────────────────────────────────────────────────────
MAX_CONCURRENT=3
MAX_TRANSCRIPT_LENGTH=15000

# ─── Optional: Official API Keys ──────────────────────────────────────
YOUTUBE_API_KEY=
